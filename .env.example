# ==============================================================================
# ESEMPIO DI CONFIGURAZIONE AMBIENTE
# ==============================================================================
# Istruzioni: Copia questo file rinominandolo in ".env" e personalizza i valori.
#
# Se desideri cambiare i valori dopo il primo avvio, dovrai:
# 1. Resettare i dati: "docker-compose down -v"
# 2. Riavviare il progetto: "docker-compose up -d --build"
# ==============================================================================

# Nome del database da creare
POSTGRES_DB=gestione_formazione

# Username scelto per il database
POSTGRES_USER=il_tuo_username

# Password scelta per il database
POSTGRES_PASSWORD=la_tua_password
