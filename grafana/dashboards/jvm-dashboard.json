{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "🟢 Application Status",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "up{job=\"springboot-app\"}", "legendFormat": "Status" }],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "steps": [{ "value": null, "color": "red" }, { "value": 1, "color": "green" }] }
        }
      }
    },
    {
      "title": "⏱️ Uptime",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "process_uptime_seconds{job=\"springboot-app\"}", "legendFormat": "Uptime" }],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "🧵 Active Threads",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "jvm_threads_live_threads{job=\"springboot-app\"}", "legendFormat": "Threads" }],
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "value": null, "color": "green" }, { "value": 100, "color": "yellow" }, { "value": 200, "color": "red" }] } } }
    },
    {
      "title": "📦 Classes Loaded",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "jvm_classes_loaded_classes{job=\"springboot-app\"}", "legendFormat": "Classes" }]
    },
    {
      "title": "💾 JVM Heap Memory Used",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "expr": "jvm_memory_used_bytes{job=\"springboot-app\", area=\"heap\"}", "legendFormat": "{{id}} - Used" },
        { "expr": "jvm_memory_max_bytes{job=\"springboot-app\", area=\"heap\"}", "legendFormat": "{{id}} - Max" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "fillOpacity": 20, "lineWidth": 2 } } }
    },
    {
      "title": "💾 JVM Non-Heap Memory Used",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "expr": "jvm_memory_used_bytes{job=\"springboot-app\", area=\"nonheap\"}", "legendFormat": "{{id}} - Used" },
        { "expr": "jvm_memory_max_bytes{job=\"springboot-app\", area=\"nonheap\"}", "legendFormat": "{{id}} - Max" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "fillOpacity": 20, "lineWidth": 2 } } }
    },
    {
      "title": "🌐 HTTP Requests Rate (per second)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "expr": "rate(http_server_requests_seconds_count{job=\"springboot-app\"}[1m])", "legendFormat": "{{method}} {{uri}} [{{status}}]" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "fillOpacity": 30, "lineWidth": 2 } } }
    },
    {
      "title": "⏳ HTTP Response Time (avg)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "expr": "rate(http_server_requests_seconds_sum{job=\"springboot-app\"}[1m]) / rate(http_server_requests_seconds_count{job=\"springboot-app\"}[1m])", "legendFormat": "{{method}} {{uri}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "fillOpacity": 10, "lineWidth": 2 } } }
    },
    {
      "title": "♻️ Garbage Collector — Pause Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "expr": "rate(jvm_gc_pause_seconds_sum{job=\"springboot-app\"}[1m])", "legendFormat": "{{action}} - {{cause}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "fillOpacity": 30, "lineWidth": 2 } } }
    },
    {
      "title": "📊 CPU Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "expr": "process_cpu_usage{job=\"springboot-app\"}", "legendFormat": "App CPU" },
        { "expr": "system_cpu_usage{job=\"springboot-app\"}", "legendFormat": "System CPU" }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "custom": { "fillOpacity": 30, "lineWidth": 2 } } }
    }
  ],
  "schemaVersion": 39,
  "tags": ["spring-boot", "jvm", "prometheus"],
  "templating": { "list": [] },
  "time": { "from": "now-30m", "to": "now" },
  "title": "Spring Boot — JVM & HTTP Monitoring",
  "uid": "springboot-jvm-dashboard",
  "version": 1
}
